# Copy to .env.local (local dev) or .env (production Docker) and fill in values.
#
# Phase 1 (local dev): point at your local Supabase stack started via `npx supabase start`.
#   Run `npx supabase status -o env` to see the current values.
# Phase 2 (self-hosted homelab): point at your self-hosted Supabase Kong API gateway.
#   NEXT_PUBLIC_SUPABASE_URL=https://api.slimelab.cc
#   NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=<ANON_KEY from Supabase .env>
# Phase 3 (cloud): point at your Supabase cloud project.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_REPLACE_ME
